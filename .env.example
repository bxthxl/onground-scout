VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
# Older Supabase projects may call this the anon key. The app supports either:
# VITE_SUPABASE_ANON_KEY=your-public-anon-key
# PayPal Business "Client ID" (from developer.paypal.com > Apps & Credentials).
# Leave unset to show a "payments almost ready" note instead of the buttons.
VITE_PAYPAL_CLIENT_ID=
